<section id="process" class="py-section bg-background" data-reveal>
  <div class="max-w-[1200px] mx-auto px-container">
    <div class="text-center mb-12">
      <h2 class="font-heading font-bold text-h2 text-text-primary mb-4">
        How We Bring Your Vision to Life
      </h2>
      <p class="text-text-secondary text-body max-w-[600px] mx-auto">
        A simple three-step process from first conversation to final walk-through.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <div class="relative text-center md:text-left">
        <div class="flex items-center gap-4 mb-4 md:mb-0 md:block">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center shrink-0 md:mb-4 md:mx-auto lg:mx-0">
            <span class="font-heading font-bold text-2xl text-primary">1</span>
          </div>
          <div class="md:hidden">
            <h3 class="font-heading font-semibold text-h3 text-text-primary">Consultation</h3>
          </div>
        </div>
        <h3 class="hidden md:block font-heading font-semibold text-h3 text-text-primary mb-3">Consultation</h3>
        <p class="text-text-secondary text-body-sm leading-relaxed">
          We visit your property, discuss your vision, and recommend plants suited to your specific environment. Bring your ideas &mdash; we&rsquo;ll bring the expertise.
        </p>
      </div>

      <div class="relative text-center md:text-left">
        <div class="flex items-center gap-4 mb-4 md:mb-0 md:block">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center shrink-0 md:mb-4 md:mx-auto lg:mx-0">
            <span class="font-heading font-bold text-2xl text-primary">2</span>
          </div>
          <div class="md:hidden">
            <h3 class="font-heading font-semibold text-h3 text-text-primary">Design</h3>
          </div>
        </div>
        <h3 class="hidden md:block font-heading font-semibold text-h3 text-text-primary mb-3">Design</h3>
        <p class="text-text-secondary text-body-sm leading-relaxed">
          Using 3D renderings or 2D plans, you&rsquo;ll see exactly what your new landscape will look like before a single plant goes in the ground. Design takes 2-6 weeks.
        </p>
      </div>

      <div class="relative text-center md:text-left">
        <div class="flex items-center gap-4 mb-4 md:mb-0 md:block">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center shrink-0 md:mb-4 md:mx-auto lg:mx-0">
            <span class="font-heading font-bold text-2xl text-primary">3</span>
          </div>
          <div class="md:hidden">
            <h3 class="font-heading font-semibold text-h3 text-text-primary">Installation</h3>
          </div>
        </div>
        <h3 class="hidden md:block font-heading font-semibold text-h3 text-text-primary mb-3">Installation</h3>
        <p class="text-text-secondary text-body-sm leading-relaxed">
          Our team arrives on time, works efficiently, and leaves your property cleaner than we found it. Every time.
        </p>
      </div>
    </div>
  </div>
</section>