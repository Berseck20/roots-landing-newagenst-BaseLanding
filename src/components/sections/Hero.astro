---
import { business } from '@data/business'
import { cta } from '@data/navigation'
---

<section id="hero" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary-dark/80 via-primary/60 to-primary-dark/80"
    role="img"
    aria-label="Completed landscape design project by Roots Landscape Service in Palm Beach Gardens — tropical plantings with palm trees and outdoor lighting"
  >
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(34,197,94,0.15),transparent_70%)]" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 max-w-[680px] mx-auto px-container text-center py-20">
    <div class="flex flex-wrap justify-center gap-3 mb-6" data-reveal>
      <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-body-sm font-medium px-3 py-1.5 rounded-full border border-white/20">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        Licensed &amp; Insured
      </span>
      <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-body-sm font-medium px-3 py-1.5 rounded-full border border-white/20">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        FNGLA Certified
      </span>
      <span class="inline-flex items-center gap-1.5 bg-white/15 backdrop-blur-sm text-white text-body-sm font-medium px-3 py-1.5 rounded-full border border-white/20">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        20+ Years Experience
      </span>
    </div>

    <h1 class="font-heading font-extrabold text-hero text-white uppercase tracking-tight mb-6" data-reveal>
      Palm Beach Gardens Landscape Design &amp; Build
    </h1>

    <p class="text-white/85 text-body max-w-[560px] mx-auto mb-4" data-reveal>
      Custom Outdoor Spaces, Rooted in Florida
    </p>

    <p class="text-white/70 text-body-sm max-w-[520px] mx-auto mb-8" data-reveal>
      Family-owned landscape design serving Palm Beach Gardens, North Palm Beach, Jupiter &amp; Tequesta. 3D renderings, Florida-friendly plants, and meticulous craftsmanship.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-reveal>
      <a
        href={cta.primary.href}
        class="inline-flex items-center justify-center gap-2 bg-accent text-white font-heading font-semibold text-lg uppercase tracking-wider px-8 py-4 rounded-md hover:bg-orange-600 transition-colors shadow-lg"
      >
        {cta.primary.text}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      {business.phone && (
        <a
          href={`tel:${business.phone.replace(/\D/g, '')}`}
          class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white font-heading font-semibold text-lg px-8 py-4 rounded-md border border-white/20 hover:bg-white/20 transition-colors"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {business.phone}
        </a>
      )}
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-bounce" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" opacity="0.6"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>