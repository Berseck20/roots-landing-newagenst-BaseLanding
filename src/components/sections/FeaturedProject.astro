---
---

<section id="featured" class="py-section bg-background" data-reveal>
  <div class="max-w-[1200px] mx-auto px-container">
    <div class="text-center mb-10">
      <h2 class="font-heading font-bold text-h2 text-text-primary mb-4">
        See What&rsquo;s Possible for Your Property
      </h2>
      <p class="text-text-secondary text-body max-w-[600px] mx-auto">
        From concept to completion — every project starts with a vision and ends with a transformation.
      </p>
    </div>

    <div class="max-w-[900px] mx-auto">
      <div class="relative rounded-xl overflow-hidden shadow-lg border border-border">
        <div class="grid grid-cols-2">
          <div class="relative aspect-[4/3] bg-surface-muted flex items-center justify-center">
            <div class="text-center p-4">
              <span class="inline-block bg-text-primary/80 text-white text-label font-heading uppercase tracking-wider px-3 py-1 rounded-sm mb-3">Before</span>
              <p class="text-text-secondary text-body-sm">Original landscape before transformation</p>
            </div>
          </div>
          <div class="relative aspect-[4/3] bg-primary/10 flex items-center justify-center">
            <div class="text-center p-4">
              <span class="inline-block bg-primary text-white text-label font-heading uppercase tracking-wider px-3 py-1 rounded-sm mb-3">After</span>
              <p class="text-text-secondary text-body-sm">Completed Roots landscape design</p>
            </div>
          </div>
        </div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-12 h-12 bg-white rounded-full shadow-lg flex items-center justify-center border-2 border-primary z-10">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-primary"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        </div>
      </div>

      <div class="text-center mt-6">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 text-accent font-heading font-semibold text-lg hover:text-orange-600 transition-colors group"
        >
          Start Your Project
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>