---
import { faq } from '@data/faq'
---

{faq.length > 0 && (
  <section id="faq" class="py-section bg-background" data-reveal>
    <div class="max-w-[800px] mx-auto px-container">
      <div class="text-center mb-10">
        <h2 class="font-heading font-bold text-h2 text-text-primary mb-4">
          Frequently Asked Questions
        </h2>
        <p class="text-text-secondary text-body">
          Everything you need to know about our landscape design and build process.
        </p>
      </div>

      <div class="space-y-3">
        {faq.map((item) => (
          <details class="group bg-surface rounded-lg border border-border overflow-hidden">
            <summary class="flex items-center justify-between p-5 cursor-pointer hover:bg-surface-muted transition-colors list-none">
              <span class="font-heading font-semibold text-text-primary text-body pr-4">{item.question}</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-secondary shrink-0 group-open:rotate-45 transition-transform" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <div class="px-5 pb-5">
              <p class="text-text-secondary text-body-sm leading-relaxed">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}